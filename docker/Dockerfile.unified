# ─────────────────────────────────────────────────────────────────────────────
# iAgents Hub — imagen unificada (backend + frontend en un solo contenedor)
#
# El contexto de build lo prepara gaia.sh push — contiene:
#   backend/   → código Python + requirements.txt
#   frontend/  → ficheros estáticos + nginx.conf
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: dependencias Python ─────────────────────────────────────────────
FROM python:3.12-slim AS py-builder
WORKDIR /build
COPY backend/requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

FROM node:22-alpine AS frontend-builder
WORKDIR /build
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build

# ── Stage 2: imagen final ─────────────────────────────────────────────────────
FROM python:3.12-slim

# nginx + supervisor + envsubst (gettext-base)
RUN apt-get update && apt-get install -y --no-install-recommends \
        nginx \
        supervisor \
        gettext-base \
    && rm -rf /var/lib/apt/lists/* \
    && rm -f /etc/nginx/sites-enabled/default

# Dependencias Python instaladas en stage anterior
COPY --from=py-builder /install /usr/local

# ── Backend ───────────────────────────────────────────────────────────────────
COPY backend/ /app/

# ── Frontend ──────────────────────────────────────────────────────────────────
COPY --from=frontend-builder /build/dist/ /usr/share/nginx/html/

# nginx.conf → conf.d/default.conf:
# · Extraer solo el bloque server{} (las directivas gzip de la cabecera van en
#   el http{} global del nginx.conf del sistema — ponerlas en conf.d las duplica)
# · Sustituir proxy_pass → 127.0.0.1 (backend en el mismo contenedor)
COPY frontend/nginx.react.conf /etc/nginx/conf.d/default.conf
RUN sed -i 's|http://backend:8765|http://127.0.0.1:8765|g' /etc/nginx/conf.d/default.conf

# ── Supervisor ────────────────────────────────────────────────────────────────
COPY supervisord.conf /etc/supervisor/conf.d/supervisord.conf

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY entrypoint-unified.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 80

# Valores por defecto sobreescribibles con -e en docker run / compose
ENV GAIA_DATA_DIR=/data \
    GAIA_HOST=127.0.0.1 \
    GAIA_PORT=8765 \
    GAIA_RELOAD=false \
    GAIA_WORKERS=4 \
    GAIA_TRUSTED_PROXIES=127.0.0.1

VOLUME ["/data"]

ENTRYPOINT ["/entrypoint.sh"]
