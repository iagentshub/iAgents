# ─────────────────────────────────────────────────────────────────────────────
# iAgents Hub — imagen unificada (backend + frontend en un solo contenedor)
#
# El contexto de build lo prepara gaia.sh push — contiene:
#   backend/   → código Python + requirements.txt
#   frontend/  → ficheros estáticos + nginx.conf
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: dependencias Python ─────────────────────────────────────────────
FROM python:3.12-slim AS py-builder
WORKDIR /build
COPY backend/requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# ── Stage 2: imagen final ─────────────────────────────────────────────────────
FROM python:3.12-slim

# nginx + supervisor + envsubst (gettext-base)
RUN apt-get update && apt-get install -y --no-install-recommends \
        nginx \
        supervisor \
        gettext-base \
    && rm -rf /var/lib/apt/lists/* \
    && rm -f /etc/nginx/sites-enabled/default

# Dependencias Python instaladas en stage anterior
COPY --from=py-builder /install /usr/local

# ── Backend ───────────────────────────────────────────────────────────────────
COPY backend/ /app/

# ── Frontend ──────────────────────────────────────────────────────────────────
COPY frontend/ /usr/share/nginx/html/

# nginx.conf: cambiar proxy_pass de "backend:8765" → "127.0.0.1:8765"
# (en imagen unificada, backend y frontend corren en el mismo contenedor)
RUN sed 's|http://backend:8765|http://127.0.0.1:8765|g' \
        /usr/share/nginx/html/nginx.conf \
        > /etc/nginx/conf.d/default.conf

# ── Supervisor ────────────────────────────────────────────────────────────────
COPY supervisord.conf /etc/supervisor/conf.d/supervisord.conf

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY entrypoint-unified.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 80

# Valores por defecto sobreescribibles con -e en docker run / compose
ENV GAIA_DATA_DIR=/data \
    GAIA_HOST=127.0.0.1 \
    GAIA_PORT=8765 \
    GAIA_RELOAD=false \
    GAIA_WORKERS=4 \
    GAIA_TRUSTED_PROXIES=127.0.0.1

VOLUME ["/data"]

ENTRYPOINT ["/entrypoint.sh"]
