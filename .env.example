# ─────────────────────────────────────────────────────────────────────────────
# iAgents Hub — Variables de entorno
# Copia este fichero a .env y rellena los valores antes de desplegar.
# El fichero .env NO se sube al repositorio (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Puertos ──────────────────────────────────────────────────────────────────
# Puerto en el que escucha el frontend (nginx)
PORT=8007
# Puerto interno del backend (FastAPI). En Docker es solo interno; el frontend lo proxya.
GAIA_PORT=8765

# ── Dominio público del frontend (sin barra final) ────────────────────────────
# Producción: https://tu-dominio.com
# Local:      http://localhost:8007
# Controla CORS, cookies seguras (https → secure) y OAuth redirect automáticamente.
GAIA_FRONTEND_URL=http://localhost:8007

# ── Secreto JWT ──────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32  — NUNCA dejes el valor vacío en producción
GAIA_AGENTS_SECRET=cambia_esto_en_produccion

# ── Admin inicial ─────────────────────────────────────────────────────────────
GAIA_ADMIN_EMAIL=admin@localhost
# Descomenta para resetear la contraseña del admin en el próximo arranque.
# Vuelve a comentar después del primer arranque.
# GAIA_ADMIN_RESET=true

# ── Registro de usuarios ──────────────────────────────────────────────────────
# open   → cualquiera puede registrarse
# closed → registro desactivado
# invite → solo el admin puede crear usuarios vía el panel
GAIA_REGISTRATION=invite

# ── Verificación de email ─────────────────────────────────────────────────────
# true  → envía correo de verificación al registrarse (requiere SMTP)
# false → los usuarios quedan verificados automáticamente
GAIA_EMAIL_VERIFY=false

# ── SMTP (recuperación de contraseña y verificación de email) ─────────────────
# Deja GAIA_SMTP_HOST vacío para deshabilitar (los tokens de reset se muestran en logs).
# Dondominio: host=mail.dondominio.com  port=587  tls=starttls
GAIA_SMTP_HOST=
GAIA_SMTP_PORT=587
# starttls (587, recomendado) | ssl (465) | none (25, solo redes internas)
GAIA_SMTP_TLS=starttls
GAIA_SMTP_USER=
GAIA_SMTP_PASS=
# Dirección "De:" en los correos — si se omite, usa GAIA_SMTP_USER
GAIA_SMTP_FROM=
# URL del webmail mostrada en el panel admin (ej: https://webmail.dondominio.com)
GAIA_WEBMAIL_URL=
# Horas de validez del enlace de recuperación de contraseña
GAIA_RESET_EXPIRE_HOURS=1

# ── Sesiones guest ────────────────────────────────────────────────────────────
GAIA_MAX_GUEST_SESSIONS=200

# ── Base de datos ─────────────────────────────────────────────────────────────
# Vacío → SQLite en GAIA_DATA_DIR/hub.db (recomendado para empezar)
# PostgreSQL → postgresql://gaia:contraseña@postgres:5432/iagentshub
DATABASE_URL=
# Contraseña de PostgreSQL (solo necesaria si DATABASE_URL apunta al servicio interno)
GAIA_DB_PASSWORD=changeme

# ── Orígenes CORS extra ───────────────────────────────────────────────────────
# Con nginx como proxy esto no suele ser necesario; déjalo vacío.
# GAIA_CORS_ORIGINS=http://localhost:8007

# ── Rate limiting (valores por defecto razonables para producción) ────────────
# GAIA_LOGIN_MAX_FAILS=5
# GAIA_LOGIN_WINDOW=300
# GAIA_RATE_CHAT_CALLS=30
# GAIA_RATE_CHAT_WINDOW=60

# ── Proxies de confianza (para X-Forwarded-For) ───────────────────────────────
# Solo se lee X-Forwarded-For cuando la conexión TCP viene de estas IPs.
# En Docker con nginx en otro contenedor, añade el gateway de la red Docker
# (suele ser 172.17.0.1 o 172.18.0.1 — comprueba con: docker network inspect <red>).
# Ejemplo: GAIA_TRUSTED_PROXIES=127.0.0.1,172.18.0.1
GAIA_TRUSTED_PROXIES=127.0.0.1

# ── Stripe (facturación, opcional) ───────────────────────────────────────────
# Obtener en dashboard.stripe.com. Dejar vacío desactiva el pago.
# Webhook secret: stripe listen --forward-to localhost:8007/api/billing/webhook
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2024-06-20
STRIPE_PRODUCT_SEATS=
STRIPE_PRICE_SELFHOSTED_MONTHLY=
STRIPE_PRICE_SELFHOSTED_ANNUAL=

# ── GitHub (repos privados) ───────────────────────────────────────────────────
# Solo necesario si los repos son privados. El token se inyecta en la URL de clone.
GITHUB_TOKEN=

# ── Repos de GitHub (modo prod — ignorado en --dev y --hub) ──────────────────
BACKEND_REPO=https://github.com/iagentshub/backend.git
FRONTEND_REPO=https://github.com/iagentshub/frontend.git
SKILLS_REPO=https://github.com/iagentshub/skills.git
AGENTS_REPO=https://github.com/iagentshub/agents.git
# Segundos entre sincronizaciones automáticas de código (3600 = 1 hora)
SYNC_INTERVAL=3600

# ── Idioma de las skills incluidas ───────────────────────────────────────────
SKILLS_LANG=es

# ── Docker Hub (modo --hub) ───────────────────────────────────────────────────
# Cuenta de Docker Hub donde se publican las imágenes con ./gaia.sh push
DOCKER_HUB_USER=iagenthub
# Tag de imagen (latest, v1.2.3, etc.)
IMAGE_TAG=latest

# ── Rutas locales para modo --dev ────────────────────────────────────────────
# Por defecto apuntan a ../backend y ../frontend (repos hermanos).
# Solo necesario si tu estructura de carpetas es diferente.
# DEV_BACKEND_REPO=/ruta/a/tu/backend
# DEV_FRONTEND_REPO=/ruta/a/tu/frontend
